{"type":"message","id":"040dfee9","parentId":"591c2055","timestamp":"2026-03-17T02:18:47.367Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"function.write:9","name":"write","arguments":{"file_path":"~/add_bitable_permission.py","content":"#!/usr/bin/env python3\n\"\"\"\nś∑ĽŚä†ť£ěšĻ¶ Bitable Ť°®ś†ľŚćŹšĹúŤÄÖśĚÉťôź\nšĹŅÁĒ®ŤĮīśėéÔľö\n1. Á°ģšŅĚŚ∑≤ťÖćÁĹģť£ěšĻ¶ App ID ŚíĆ App Secret\n2. ŤŅźŤ°Ć: python add_bitable_permission.py\n\"\"\"\n\nimport requests\nimport json\n\n# ============ ťÖćÁĹģ ============\n# ť£ěšĻ¶ŚļĒÁĒ®Śá≠ŤĮĀ\nAPP_ID = \"cli_a922eb10d3345bd9\"  # ŚįŹÁĆéÁöĄť£ěšĻ¶ App ID\nAPP_SECRET = \"RmuIQUydfwh3s2sMYyaPCgG0a0PNWDvq\"  # ŚįŹÁĆéÁöĄť£ěšĻ¶ App Secret\n\n# Ť°®ś†ľšŅ°śĀĮ\nAPP_TOKEN = \"YwLebIyl1aC2KfsLBOacWivOn1b\"  # Ť°®ś†ľ token\n\n# Ť¶Āś∑ĽŚä†ÁöĄŚćŹšĹúŤÄÖ\n# ŚĘ®ŚĘ®ÁöĄ open_id (ťúÄŤ¶Āśü•ŤĮĘŤé∑ŚŹĖ)\nCOLLABORATOR_OPEN_ID = \"ou_44a485e0921ccfa29b3fa386eb33eff7\"  # ŤŅôśėĮšĹ†ÁöĄ open_idÔľĆťúÄŤ¶ĀśćĘśąźŚĘ®ŚĘ®ÁöĄ\n\n# śĚÉťôźÁĪĽŚěč: \"admin\"=ŚŹĮÁģ°ÁźÜ, \"edit\"=ŚŹĮÁľĖŤĺĎ, \"read\"=ŚŹĮťėÖŤĮĽ\nPERMISSION = \"admin\"\n# ==============================\n\n\ndef get_tenant_access_token(app_id, app_secret):\n    \"\"\"Ťé∑ŚŹĖ tenant_access_token\"\"\"\n    url = \"https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal\"\n    headers = {\"Content-Type\": \"application/json\"}\n    data = {\n        \"app_id\": app_id,\n        \"app_secret\": app_secret\n    }\n    \n    response = requests.post(url, headers=headers, json=data)\n    result = response.json()\n    \n    if result.get(\"code\") == 0:\n        return result[\"tenant_access_token\"]\n    else:\n        print(f\"Ťé∑ŚŹĖ token Ś§ĪŤī•: {result}\")\n        return None\n\n\ndef get_user_open_id(token, user_id):\n    \"\"\"ťÄöŤŅá user_id Ťé∑ŚŹĖ open_id\"\"\"\n    # Ś¶āśěúśėĮťāģÁģĪśąĖśČčśúļŚŹ∑ÔľĆťúÄŤ¶ĀŚÖąśü•ŤĮĘÁĒ®śą∑šŅ°śĀĮ\n    url = f\"https://open.feishu.cn/open-apis/contact/v3/users/{user_id}\"\n    headers = {\n        \"Authorization\": f\"Bearer {token}\",\n        \"Content-Type\": \"application/json\"\n    }\n    \n    response = requests.get(url, headers=headers)\n    result = response.json()\n    \n    if result.get(\"code\") == 0:\n        return result[\"data\"][\"user\"][\"open_id\"]\n    else:\n        print(f\"Ťé∑ŚŹĖÁĒ®śą∑šŅ°śĀĮŚ§ĪŤī•: {result}\")\n        return None\n\n\ndef add_bitable_collaborator(token, app_token, open_id, permission):\n    \"\"\"\n    ś∑ĽŚä† Bitable ŚćŹšĹúŤÄÖ\n    ś≥®śĄŹÔľöť£ěšĻ¶ API ÁõģŚČćšłćÁõīśé•śĒĮśĆĀťÄöŤŅá API ś∑ĽŚä†ŚćŹšĹúŤÄÖ\n    ŤŅôšł™ŚáĹśēįśľĒÁ§ļšļÜŚ¶āšĹēŤįÉÁĒ®ÁõłŚÖ≥ API\n    \"\"\"\n    # ť£ěšĻ¶ÁõģŚČćś≤°śúČÁõīśé•ÁöĄ \"ś∑ĽŚä† Bitable ŚćŹšĹúŤÄÖ\" API\n    # ťúÄŤ¶ĀťÄöŤŅášĽ•šłčśĖĻŚľŹšĻčšłÄÔľö\n    \n    # śĖĻŚľŹ 1: šĹŅÁĒ® Drive API (Ś¶āśěúŤ°®ś†ľŚú®šļĎÁęĮÁ°¨Áõė)\n    url = f\"https://open.feishu.cn/open-apis/drive/v1/files/{app_token}/permissions\"\n    headers = {\n        \"Authorization\": f\"Bearer {token}\",\n        \"Content-Type\": \"application/json\"\n    }\n    data = {\n        \"member\": {\n            \"member_type\": \"open_id\",\n            \"member_id\": open_id\n        },\n        \"perm\": permission  # \"admin\", \"edit\", \"view\"\n    }\n    \n    response = requests.post(url, headers=headers, json=data)\n    result = response.json()\n    \n    print(f\"ś∑ĽŚä†ŚćŹšĹúŤÄÖÁĽďśěú: {json.dumps(result, indent=2, ensure_ascii=False)}\")\n    return result\n\n\ndef list_bitable_collaborators(token, app_token):\n    \"\"\"ŚąóŚáļŤ°®ś†ľŚĹďŚČćÁöĄŚćŹšĹúŤÄÖ\"\"\"\n    url = f\"https://open.feishu.cn/open-apis/drive/v1/files/{app_token}/permissions\"\n    headers = {\n        \"Authorization\": f\"Bearer {token}\",\n        \"Content-Type\": \"application/json\"\n    }\n    \n    response = requests.get(url, headers=headers)\n    result = response.json()\n    \n    print(f\"ŚĹďŚČćŚćŹšĹúŤÄÖŚąóŤ°®: {json.dumps(result, indent=2, ensure_ascii=False)}\")\n    return result\n\n\ndef main():\n    print(\"=\" * 50)\n    print(\"ť£ěšĻ¶ Bitable śĚÉťôźÁģ°ÁźÜŚ∑•ŚÖ∑\")\n    print(\"=\" * 50)\n    \n    # 1. Ťé∑ŚŹĖ access token\n    print(\"\\n[1/3] Ťé∑ŚŹĖ tenant_access_token...\")\n    token = get_tenant_access_token(APP_ID, APP_SECRET)\n    if not token:\n        print(\"‚ĚĆ Ťé∑ŚŹĖ token Ś§ĪŤī•ÔľĆŤĮ∑ś£Äśü• App ID ŚíĆ App Secret\")\n        return\n    print(\"‚úÖ Token Ťé∑ŚŹĖśąźŚäü\")\n    \n    # 2. śü•ÁúčŚĹďŚČćŚćŹšĹúŤÄÖ\n    print(\"\\n[2/3] śü•ÁúčŚĹďŚČćŚćŹšĹúŤÄÖ...\")\n    collaborators = list_bitable_collaborators(token, APP_TOKEN)\n    \n    # 3. ś∑ĽŚä†ŚĘ®ŚĘ®šłļŚćŹšĹúŤÄÖ\n    print(\"\\n[3/3] ś∑ĽŚä†ŚĘ®ŚĘ®šłļŚćŹšĹúŤÄÖ...\")\n    print(f\"Áõģś†áÁĒ®śą∑ open_id: {COLLABORATOR_OPEN_ID}\")\n    print(f\"śĚÉťôźÁļßŚąę: {PERMISSION}\")\n    \n    result = add_bitable_collaborator(token, APP_TOKEN, COLLABORATOR_OPEN_ID, PERMISSION)\n    \n    if result.get(\"code\") == 0:\n        print(\"\\n‚úÖ ś∑ĽŚä†śąźŚäüÔľĀ\")\n        print(f\"ŚĘ®ŚĘ®ÁéįŚú®śč•śúČ„ÄĆ{'ŚŹĮÁģ°ÁźÜ' if PERMISSION == 'admin' else 'ŚŹĮÁľĖŤĺĎ' if PERMISSION == 'edit' else 'ŚŹĮťėÖŤĮĽ'}„ÄćśĚÉťôź\")\n    else:\n        print(f\"\\n‚ĚĆ ś∑ĽŚä†Ś§ĪŤī•: {result.get('msg', 'śú™Áü•ťĒôŤĮĮ')}\")\n        print(\"\\nŚŹĮŤÉĹÁöĄŚéüŚõ†Ôľö\")\n        print(\"1. ť£ěšĻ¶ API šłćśĒĮśĆĀÁõīśé•ś∑ĽŚä† Bitable ŚćŹšĹúŤÄÖ\")\n        print(\"2. ťúÄŤ¶ĀśČčŚä®Śú®ÁĹĎť°ĶÁęĮś∑ĽŚä†\")\n        print(\"3. App ÁľļŚįĎÁõłŚÖ≥śĚÉťôź scope\")\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"bailian","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773713895170}}
