{"type":"message","id":"69791451","parentId":"f8fcdf08","timestamp":"2026-03-15T22:31:12.730Z","message":{"role":"toolResult","toolCallId":"functions.read:0","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n# 墨墨的 OpenClaw 早报 - 每天凌晨 5 点\n# 抓取信息 → 生成早报 → 推送到飞书\n\nset -e\n\n# 加载 OpenClaw 环境变量\nif [ -f ~/.openclaw/.env ]; then\n    set -a\n    source ~/.openclaw/.env\n    set +a\nfi\n\nWORKSPACE=~/Documents/openclaw/agents/writer\nBRIEFING_DIR=\"$WORKSPACE/memory/早报\"\nTODAY=$(date +%Y-%m-%d)\nBRIEFING_FILE=\"$BRIEFING_DIR/$TODAY.md\"\n\n# 飞书 webhook URL（从环境变量读取）\nFEISHU_WEBHOOK=\"${FEISHU_WEBHOOK:-}\"\n\necho \"🌅 墨墨的 OpenClaw 早报\"\necho \"======================\"\necho \"📅 日期：$TODAY\"\necho \"\"\n\n# 创建早报目录\nmkdir -p \"$BRIEFING_DIR\"\n\n# 1. 抓取信息并生成早报\necho \"📰 生成早报内容...\"\n\ncat > \"$BRIEFING_FILE\" << 'HEADER'\n# 🌅 墨墨的 OpenClaw 早报\n\nHEADER\n\necho \"**日期:** $TODAY\" >> \"$BRIEFING_FILE\"\necho \"**第:** $(ls -1 \"$BRIEFING_DIR\"/*.md 2>/dev/null | wc -l | tr -d ' ') **期**\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 检查 OpenClaw 版本\necho \"## 📦 当前环境\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nOPENCLAW_VERSION=$(openclaw --version 2>/dev/null || echo \"未知\")\necho \"- **OpenClaw 版本:** $OPENCLAW_VERSION\" >> \"$BRIEFING_FILE\"\necho \"- **工作区:** $WORKSPACE\" >> \"$BRIEFING_FILE\"\necho \"- **生成时间:** $(date +%H:%M)\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 检查技能更新\necho \"## 🛠️ 技能状态\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nSKILL_COUNT=$(ls -d ~/.openclaw/skills/* 2>/dev/null | wc -l | tr -d ' ')\necho \"- **已安装技能:** $SKILL_COUNT 个\" >> \"$BRIEFING_FILE\"\necho \"- **技能目录:** ~/.openclaw/skills/\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\necho \"### 已安装技能列表\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nls ~/.openclaw/skills/ 2>/dev/null | while read skill; do\n    echo \"- $skill\" >> \"$BRIEFING_FILE\"\ndone\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 检查备份状态\necho \"## 🗄️ 备份状态\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nLATEST_BACKUP=$(ls -t ~/Documents/openclaw/backups/ | grep \"墨墨-momo\" | head -1)\nif [ -n \"$LATEST_BACKUP\" ]; then\n    BACKUP_SIZE=$(du -sh ~/Documents/openclaw/backups/$LATEST_BACKUP 2>/dev/null | cut -f1)\n    echo \"- **最新备份:** $LATEST_BACKUP\" >> \"$BRIEFING_FILE\"\n    echo \"- **备份大小:** $BACKUP_SIZE\" >> \"$BRIEFING_FILE\"\nelse\n    echo \"- ⚠️ 暂无备份记录\" >> \"$BRIEFING_FILE\"\nfi\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 检查进化状态\necho \"## 🧬 进化状态\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nif [ -f ~/.openclaw/skills/evolver/assets/gep/events.jsonl ]; then\n    EVOLUTION_COUNT=$(wc -l < ~/.openclaw/skills/evolver/assets/gep/events.jsonl | tr -d ' ')\n    LAST_EVENT=$(tail -1 ~/.openclaw/skills/evolver/assets/gep/events.jsonl 2>/dev/null | grep -o '\"at\":\"[^\"]*\"' | cut -d'\"' -f4 || echo \"未知\")\n    echo \"- **进化事件总数:** $EVOLUTION_COUNT\" >> \"$BRIEFING_FILE\"\n    echo \"- **最近进化:** $LAST_EVENT\" >> \"$BRIEFING_FILE\"\nelse\n    echo \"- 未启用进化引擎\" >> \"$BRIEFING_FILE\"\nfi\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 今日建议\necho \"## 📋 今日建议\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\necho \"- [ ] 查看早报，了解新动态\" >> \"$BRIEFING_FILE\"\necho \"- [ ] 检查备份是否正常\" >> \"$BRIEFING_FILE\"\necho \"- [ ] 回顾进化记录\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 墨墨的话\necho \"## 🖤 墨墨的话\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\necho \"哥哥早安！这是今天的 OpenClaw 状态报告～\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\necho \"一切正常，我会在飞书等你查看详细内容！\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\n# 神探墨墨搜索 - OpenClaw 新动态\necho \"## 🔍 神探墨墨搜索 - OpenClaw 新动态\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 进化详情\necho \"### 🧬 进化事件详情\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nif [ -f ~/.openclaw/skills/evolver/assets/gep/events.jsonl ]; then\n    EVENT_COUNT=$(wc -l < ~/.openclaw/skills/evolver/assets/gep/events.jsonl | tr -d ' ')\n    echo \"**总进化事件数:** $EVENT_COUNT\" >> \"$BRIEFING_FILE\"\n    echo \"\" >> \"$BRIEFING_FILE\"\n    \n    # 读取胶囊信息\n    if [ -f ~/.openclaw/skills/evolver/assets/gep/capsules.json ]; then\n        CAPSULE_COUNT=$(cat ~/.openclaw/skills/evolver/assets/gep/capsules.json | grep -c '\"id\": \"capsule_' || echo 0)\n        echo \"**成功固化胶囊:** $CAPSULE_COUNT 个\" >> \"$BRIEFING_FILE\"\n        echo \"\" >> \"$BRIEFING_FILE\"\n        \n        # 显示最近的进化\n        echo \"**最近进化详情:**\" >> \"$BRIEFING_FILE\"\n        cat ~/.openclaw/skills/evolver/assets/gep/capsules.json | grep -A 5 '\"summary\"' | head -20 | while read line; do\n            echo \"$line\" | sed 's/\"summary\": \"//g' | sed 's/\"$//g' | sed 's/^/  /' >> \"$BRIEFING_FILE\"\n        done\n    fi\nelse\n    echo \"- 未启用进化引擎\" >> \"$BRIEFING_FILE\"\nfi\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 获取 GitHub 最新 commits\necho \"### 📦 官方更新\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nLATEST_COMMITS=$(curl -s \"https://api.github.com/repos/openclaw/openclaw/commits?per_page=3\" 2>/dev/null)\nif [ -n \"$LATEST_COMMITS\" ]; then\n    echo \"**最近 Commits:**\" >> \"$BRIEFING_FILE\"\n    # 使用更简单的解析方式\n    echo \"$LATEST_COMMITS\" | grep -o '\"date\": \"[^\"]*\"' | head -3 > /tmp/commit_dates.txt\n    echo \"$LATEST_COMMITS\" | grep -o '\"message\": \"[^\"]*\"' | head -3 > /tmp/commit_msgs.txt\n    paste /tmp/commit_dates.txt /tmp/commit_msgs.txt | while IFS=$'\\t' read date msg; do\n        DATE_CLEAN=$(echo \"$date\" | cut -d'\"' -f4 | cut -dT -f1)\n        MSG_CLEAN=$(echo \"$msg\" | cut -d'\"' -f4 | cut -c1-60)\n        echo \"- **$DATE_CLEAN**: $MSG_CLEAN\" >> \"$BRIEFING_FILE\"\n    done\n    rm -f /tmp/commit_dates.txt /tmp/commit_msgs.txt\nelse\n    echo \"- 暂无法获取 commit 信息\" >> \"$BRIEFING_FILE\"\nfi\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 获取最新 release\necho \"**版本状态:**\" >> \"$BRIEFING_FILE\"\nLATEST_RELEASE=$(curl -s \"https://api.github.com/repos/openclaw/openclaw/releases?per_page=1\" 2>/dev/null)\nif [ -n \"$LATEST_RELEASE\" ]; then\n    RELEASE_TAG=$(echo \"$LATEST_RELEASE\" | grep -o '\"tag_name\": \"[^\"]*\"' | head -1 | cut -d'\"' -f4)\n    RELEASE_DATE=$(echo \"$LATEST_RELEASE\" | grep -o '\"published_at\": \"[^\"]*\"' | head -1 | cut -d'\"' -f4 | cut -dT -f1)\n    echo \"- 最新 Release: $RELEASE_TAG ($RELEASE_DATE)\" >> \"$BRIEFING_FILE\"\n    echo \"- 本地版本: $OPENCLAW_VERSION\" >> \"$BRIEFING_FILE\"\n    if [ \"$OPENCLAW_VERSION\" = \"${RELEASE_TAG#v}\" ]; then\n        echo \"- ✅ 版本已是最新\" >> \"$BRIEFING_FILE\"\n    else\n        echo \"- ⚠️ 有新版本可用\" >> \"$BRIEFING_FILE\"\n    fi\nelse\n    echo \"- 暂无法获取 release 信息\" >> \"$BRIEFING_FILE\"\nfi\necho \"\" >> \"$BRIEFING_FILE\"\n\n# 技能市场检查\necho \"### 🛠️ 技能市场\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\nSKILL_COUNT=$(ls -d ~/.openclaw/skills/* 2>/dev/null | wc -l | tr -d ' ')\necho \"- 已安装技能：$SKILL_COUNT 个\" >> \"$BRIEFING_FILE\"\necho \"- 技能目录：~/.openclaw/skills/\" >> \"$BRIEFING_FILE\"\necho \"- 🔗 ClawHub: https://clawhub.com\" >> \"$BRIEFING_FILE\"\necho \"\" >> \"$BRIEFING_FILE\"\n\necho \"---\" >> \"$BRIEFING_FILE\"\necho \"*自动生成于 $(date)*\" >> \"$BRIEFING_FILE\"\n\necho \"   ✅ 早报已生成：$BRIEFING_FILE\"\n\n# 2. 推送到飞书\nif [ -n \"$FEISHU_WEBHOOK\" ]; then\n    echo \"\"\n    echo \"📬 推送到飞书...\"\n    \n    # 获取神探墨墨搜索的摘要信息\n    LATEST_COMMIT_MSG=$(curl -s \"https://api.github.com/repos/openclaw/openclaw/commits?per_page=1\" 2>/dev/null | grep -o '\"message\": \"[^\"]*\"' | head -1 | cut -d'\"' -f4 | cut -c1-40)\n    LATEST_RELEASE=$(curl -s \"https://api.github.com/repos/openclaw/openclaw/releases?per_page=1\" 2>/dev/null | grep -o '\"tag_name\": \"[^\"]*\"' | head -1 | cut -d'\"' -f4)\n    \n    # 发送完整早报内容（使用 text 类型）\n    curl -s -X POST -H \"Content-Type: application/json\" \"$FEISHU_WEBHOOK\" -d \"{\n        \\\"msg_type\\\": \\\"text\\\",\n        \\\"content\\\": {\n            \\\"text\\\": \\\"🌅 墨墨的 OpenClaw 早报 - $TODAY\\\\n\\\\n哥哥早安！今天的状态报告已生成～\\\\n\\\\n📦 OpenClaw 版本：$(openclaw --version 2>/dev/null || echo '未知')\\\\n🛠️ 已安装技能：$(ls -d ~/.openclaw/skills/* 2>/dev/null | wc -l | tr -d ' ') 个\\\\n🗄️ 最新备份：$(ls -t ~/Documents/openclaw/backups/ 2>/dev/null | grep '墨墨-momo' | head -1 || echo '暂无')\\\\n🧬 进化事件：$(wc -l < ~/.openclaw/skills/evolver/assets/gep/events.jsonl 2>/dev/null | tr -d ' ' || echo 0) 次\\\\n🔍 最新 Commit: $LATEST_COMMIT_MSG\\\\n📦 最新 Release: $LATEST_RELEASE\\\\n\\\\n详细内容请查看：$BRIEFING_FILE\\\"\n        }\n    }\"\n    echo \"\"\n    echo \"   ✅ 飞书推送完成\"\nelse\n    echo \"\"\n    echo \"⚠️  未配置 FEISHU_WEBHOOK，跳过推送\"\n    echo \"   请在 .env 文件中设置 FEISHU_WEBHOOK 变量\"\nfi\n\necho \"\"\necho \"✅ 早报生成完成！\"\necho \"📍 文件位置：$BRIEFING_FILE\"\necho \"\"\n"}],"isError":false,"timestamp":1773613872726}}
