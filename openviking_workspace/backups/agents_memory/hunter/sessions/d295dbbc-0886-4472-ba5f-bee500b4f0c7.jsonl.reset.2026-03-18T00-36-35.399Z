{"type":"message","id":"756a052d","parentId":"963c774f","timestamp":"2026-03-17T01:16:55.471Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，继续批量写入剩余的评论。我需要读取更多数据并继续写入。让我继续批量处理。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"继续批量写入全部评论，让我创建一个脚本来自动处理所有评论：\n\n"},{"type":"toolCall","id":"call_d377085419444e2e8d7261cd","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n批量上传全部评论到飞书表格\n\"\"\"\n\nimport json\nimport subprocess\nimport time\n\n# 飞书配置\nFEISHU_APP_TOKEN = \"YwLebIyl1aC2KfsLBOacWivOn1b\"\nFEISHU_TABLE_ID = \"tblKU26iyNNK3Ci0\"\n\n# 问题关键词分类\nISSUE_KEYWORDS = {\n    \"崩溃/闪退\": [\"崩溃\", \"闪退\", \"黑屏\", \"白屏\", \"死机\", \"卡死\", \"无响应\", \"crash\", \"freeze\"],\n    \"卡顿/掉帧\": [\"卡顿\", \"掉帧\", \"延迟\", \"lag\", \"不流畅\", \"帧数\", \"fps\", \"慢\", \"卡\", \"性能\", \"stuttering\"],\n    \"Bug/错误\": [\"bug\", \"Bug\", \"错误\", \"失败\", \"缺陷\", \"漏洞\", \"异常\", \"报错\", \"出错\", \"毛病\", \"问题\", \"故障\"],\n    \"优化问题\": [\"优化\", \"配置\", \"硬件\", \"显卡\", \"CPU\", \"内存\", \"发热\", \"功耗\", \"效率\"],\n    \"网络/连接\": [\"网络\", \"联机\", \"在线\", \"连接\", \"服务器\", \"掉线\", \"断连\", \"disconnect\", \"ping\", \"登录\"],\n    \"启动/进入\": [\"启动\", \"打开\", \"进入\", \"加载\", \"载入\", \"初始化\", \"launcher\", \"启动器\"],\n    \"存档/进度\": [\"存档\", \"保存\", \"进度\", \"丢失\", \"损坏\", \"save\", \"cloud\", \"云存档\", \"同步\"],\n    \"音频/画面\": [\"声音\", \"音频\", \"音乐\", \"音效\", \"无声\", \"杂音\", \"画面\", \"贴图\", \"渲染\", \"花屏\"],\n    \"操作/控制\": [\"操作\", \"控制\", \"按键\", \"键盘\", \"鼠标\", \"手柄\", \"输入\", \"响应\", \"失灵\"],\n    \"其他问题\": [\"失望\", \"差\", \"不好\", \"烂\", \"垃圾\", \"坑\", \"后悔\", \"浪费\", \"不值\", \"一般\", \"贵\"]\n}\n\ndef parse_playtime(playtime_forever):\n    if not playtime_forever:\n        return \"未知\"\n    hours = playtime_forever // 60\n    minutes = playtime_forever % 60\n    if hours == 0:\n        return f\"{minutes} 分钟\"\n    elif hours < 10:\n        return f\"{hours}小时{minutes}分\"\n    else:\n        return f\"{hours}小时\"\n\ndef analyze_review(text):\n    matched_keywords = []\n    issue_types = set()\n    text_lower = text.lower()\n    \n    for issue_type, keywords in ISSUE_KEYWORDS.items():\n        for keyword in keywords:\n            if keyword.lower() in text_lower:\n                matched_keywords.append(keyword)\n                issue_types.add(issue_type)\n    \n    matched_keywords = list(dict.fromkeys(matched_keywords))\n    return matched_keywords, list(issue_types) if issue_types else [\"其他问题\"]\n\ndef create_feishu_record(fields):\n    try:\n        cmd = [\n            \"openclaw\", \"feishu\", \"bitable\", \"create_record\",\n            \"--app_token\", FEISHU_APP_TOKEN,\n            \"--table_id\", FEISHU_TABLE_ID,\n            \"--fields\", json.dumps(fields, ensure_ascii=False)\n        ]\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=10)\n        return result.returncode == 0\n    except:\n        return False\n\ndef main():\n    # 读取全部评论\n    with open(\"steam_reviews_3679080_all.json\", \"r\", encoding=\"utf-8\") as f:\n        all_reviews = json.load(f)\n    \n    print(f\"📊 共 {len(all_reviews)} 条评论待上传\")\n    print(\"=\" * 60)\n    \n    uploaded = 0\n    for i, item in enumerate(all_reviews):\n        review = item.get(\"review\", {})\n        lang_code = item.get(\"language\", \"schinese\")\n        lang_name = \"简体中文\" if lang_code == \"schinese\" else \"繁体中文\"\n        \n        author = review.get(\"author\", {})\n        text = review.get(\"review\", \"\")\n        playtime = review.get(\"playtime_forever\", 0)\n        recommended = bool(review.get(\"recommendationid\"))\n        timestamp = review.get(\"timestamp_created\")\n        \n        # 分析评论\n        keywords, issue_types = analyze_review(text)\n        \n        fields = {\n            \"评论内容\": text[:5000],\n            \"作者\": author.get(\"personaname\", \"匿名\"),\n            \"推荐状态\": \"推荐\" if recommended else \"不推荐\",\n            \"游戏时长\": parse_playtime(playtime),\n            \"评论日期\": timestamp,\n            \"问题类型\": issue_types,\n            \"匹配关键词\": \", \".join(keywords[:15]) if keywords else \"无\",\n            \"评论链接\": f\"https://steamcommunity.com/app/3679080/reviews/?language={lang_code}\",\n            \"处理状态\": \"已记录\",\n            \"语言\": lang_name\n        }\n        \n        print(f\"[{i+1}/{len(all_reviews)}] 上传：{author.get('personaname', '匿名')[:20]}... \", end=\"\")\n        \n        if create_feishu_record(fields):\n            print(\"✅\")\n            uploaded += 1\n        else:\n            print(\"⚠️ 失败\")\n        \n        time.sleep(0.15)\n    \n    print(\"=\" * 60)\n    print(f\"✅ 上传完成！成功：{uploaded}/{len(all_reviews)}\")\n    print(f\"🔗 飞书表格：https://xcnb9qtctplo.feishu.cn/base/{FEISHU_APP_TOKEN}\")\n\nif __name__ == \"__main__\":\n    main()\n","path":"~/upload_all_to_feishu.py"}}],"api":"openai-completions","provider":"bailian","model":"qwen3.5-plus","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773710159918}}
