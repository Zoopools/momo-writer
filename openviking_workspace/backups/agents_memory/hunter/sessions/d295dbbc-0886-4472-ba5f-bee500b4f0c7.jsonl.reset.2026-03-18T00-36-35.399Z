ull,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"其他问题\"\n        ]\n      },\n      \"id\": \"recve5cpBLAdVY\",\n      \"record_id\": \"recve5cpBLAdVY\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"Sanda\",\n        \"匹配关键词\": \"卡死\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏时长\": \"3 小时 28 分\",\n        \"评论内容\": \"做任务 直接卡死，什么都干不了，也脱离不了，血条是 9999999.退出重登也是这样，想换号重新玩，发现已经和 steam 绑定了。\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"崩溃/闪退\",\n          \"Bug/错误\"\n        ]\n      },\n      \"id\": \"recve5cpCoF8j0\",\n      \"record_id\": \"recve5cpCoF8j0\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"玩家 1\",\n        \"匹配关键词\": \"垃圾，优化，差，卡顿\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏时长\": \"30 分钟\",\n        \"评论内容\": \"垃圾游戏，优化差，卡顿严重\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"优化问题\",\n          \"卡顿/掉帧\"\n        ]\n      },\n      \"id\": \"recve5cpCuTHBo\",\n      \"record_id\": \"recve5cpCuTHBo\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"鲨鱼辣椒\",\n        \"匹配关键词\": \"不足，氪金\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏时长\": \"1 小时\",\n        \"评论内容\": \"期待了很久的一款游戏。喜欢这个 ip 也和朋友介绍了好多次。结果呈现上来的就这个？从跑步到战斗系统都是依托大的了。拜托，现在都是 2026 年，还不如 2020 年的原神。哪儿哪儿都不足。就是喜欢拿 ip 氪金。终极粉丝可以试试看。我是吃不了一点，朋友面前抬不起头，散会！\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"其他问题\"\n        ]\n      },\n      \"id\": \"recve5cDgAhxRG\",\n      \"record_id\": \"recve5cDgAhxRG\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"玩家 4\",\n        \"匹配关键词\": \"无法启动，黑屏\",\n        \"处理状态\": \"待处理\",\n        \"推荐状