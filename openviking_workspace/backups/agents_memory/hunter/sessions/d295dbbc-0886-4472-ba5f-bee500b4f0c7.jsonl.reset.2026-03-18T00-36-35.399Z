e5cpBvaE2n\",\n      \"record_id\": \"recve5cpBvaE2n\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"OuYue\",\n        \"匹配关键词\": \"差\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏名称\": null,\n        \"游戏时长\": \"5 小时 26 分\",\n        \"评论内容\": \"剧情打 boss 引导非常差劲，NPC 莫名其妙一句话就过去了也不给你个提示标该怎么样\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"其他问题\"\n        ]\n      },\n      \"id\": \"recve5cpBLAdVY\",\n      \"record_id\": \"recve5cpBLAdVY\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"Sanda\",\n        \"匹配关键词\": \"卡死\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏名称\": null,\n        \"游戏时长\": \"3 小时 28 分\",\n        \"评论内容\": \"做任务 直接卡死，什么都干不了，也脱离不了，血条是 9999999.退出重登也是这样，想换号重新玩，发现已经和 steam 绑定了。\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"崩溃/闪退\",\n          \"Bug/错误\"\n        ]\n      },\n      \"id\": \"recve5cpCoF8j0\",\n      \"record_id\": \"recve5cpCoF8j0\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"玩家 1\",\n        \"匹配关键词\": \"垃圾，优化，差，卡顿\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏名称\": null,\n        \"游戏时长\": \"30 分钟\",\n        \"评论内容\": \"垃圾游戏，优化差，卡顿严重\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"优化问题\",\n          \"卡顿/掉帧\"\n        ]\n      },\n      \"id\": \"recve5cpCuTHBo\",\n      \"record_id\": \"recve5cpCuTHBo\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"鲨鱼辣椒\",\n        \"匹配关键词\": \"不足，氪金\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏名称\": \"七大罪 (app/3679080)\",\n        \"游戏时长\": \"1 小时\",\n        \"评论内容\": \"期待了很久的一款游戏。喜欢这个 ip 也和朋友介绍了好多次。结果呈现上来的就这个？从跑步到战斗系统都是依托大的了。拜托，现在都是 2026 年，还不如 2020 年的原神。哪儿哪儿都不足。就是喜欢拿 ip 氪金。终极粉丝可以试试看。我是吃不了一点，朋友面前抬不起头，散会！\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"其他问题\"\n        ]\n      },\n      \"id\": \"recve5cDgAhxRG\",\n      \"record_id\": \"recve5cDgAhxRG\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"玩家 4\",\n        \"匹配关键词\": \"无法启动，黑屏\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏名称\": null,\n        \"游戏时长\": \"0 分钟\",\n        \"评论内容\": \"游戏无法启动，一直黑屏\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"启动/进入\",\n          \"崩溃/闪退\"\n        ]\n      },\n      \"id\": \"recve5cDgrGNwY\",\n      \"record_id\": \"recve5cDgrGNwY\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"Urakan\",\n        \"匹配关键词\": \"帧数，卡，坑\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏名称\": null,\n        \"游戏时长\": \"2 小时 30 分\",\n        \"评论内容\": \"5070 在这个游戏面前像个新兵蛋子，地图糊的没眼看，帧数波动极大，角色培养到卡池里里外外都是坑，低配版换皮元神真操了\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"卡顿/掉帧\",\n          \"其他问题\"\n        ]\n      },\n      \"id\": \"recve5cDgjqMrz\",\n      \"record_id\": \"recve5cDgjqMrz\"\n    },\n    {\n      \"fields\": {\n        \"Steam 游戏问题评论追踪\": null,\n        \"作者\": \"玩家 2\",\n        \"匹配关键词\": \"优化，差\",\n        \"处理状态\": \"待处理\",\n        \"推荐状态\": \"不推荐\",\n        \"游戏名称\": null,\n        \"游戏时长\": \"15 分钟\",\n        \"评论内容\": \"优化太差了，根本玩不了\",\n        \"评论日期\": null,\n        \"评论链接\": null,\n        \"语言\": \"简体中文\",\n        \"问题类型\": [\n          \"优化问题\"\n        ]\n      },\n      \"id\": \"recve5cDgCFtct\",\n      \"record_id\": \"recve5cDgCFtct\"\n    }\n  ],\n  \"has_more\": true,\n  \"page_token\": \"recve5cDgCFtct\",\n  \"total\": 50\n}"}],"details":{"records":[{"fi