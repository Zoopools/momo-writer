{"type":"message","id":"98ca393e","parentId":"2b966089","timestamp":"2026-03-17T01:03:49.817Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"太好了，所有字段都创建成功了。现在我需要更新爬取脚本，让它可以直接把数据写入飞书表格。让我创建一个新版本的脚本，包含飞书 API 集成。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"✅ 飞书表格已创建成功！\n\n**表格链接：** https://xcnb9qtctplo.feishu.cn/base/YwLebIyl1aC2KfsLBOacWivOn1b\n\n**表格字段：**\n| 字段名 | 类型 |\n|--------|------|\n| 评论内容 | 文本 |\n| 作者 | 文本 |\n| 推荐状态 | 单选 (推荐/不推荐) |\n| 游戏时长 | 文本 |\n| 评论日期 | 日期时间 |\n| 问题类型 | 多选 (崩溃/卡顿/Bug/优化/其他) |\n| 匹配关键词 | 文本 |\n| 评论链接 | URL |\n| 处理状态 | 单选 (待处理/已记录/已反馈/已解决) |\n\n现在我更新爬取脚本，让它可以直接把数据写入飞书表格：\n\n"},{"type":"toolCall","id":"call_51b5d1275a4a49e4b2b972fe","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nSteam 评论爬取脚本 - 飞书集成版\n爬取指定游戏的简体中文评论，筛选关于游戏问题的评论并写入飞书表格\n\"\"\"\n\nimport requests\nimport json\nimport time\nimport re\nfrom datetime import datetime\n\n# ========== 配置区域 ==========\n# 游戏 ID (从 URL app/3679080 获取)\nAPP_ID = \"3679080\"\n\n# 飞书配置\nFEISHU_APP_TOKEN = \"YwLebIyl1aC2KfsLBOacWivOn1b\"\nFEISHU_TABLE_ID = \"tblKU26iyNNK3Ci0\"\nFEISHU_API = \"https://open.feishu.cn/open-apis/bitable/v1/apps\"\n\n# 关键词：用于筛选\"关于游戏问题\"的评论\nGAME_ISSUE_KEYWORDS = [\n    (\"崩溃\", \"崩溃/闪退\"), (\"闪退\", \"崩溃/闪退\"), (\"黑屏\", \"崩溃/闪退\"),\n    (\"卡顿\", \"卡顿/掉帧\"), (\"掉帧\", \"卡顿/掉帧\"), (\"延迟\", \"卡顿/掉帧\"),\n    (\"bug\", \"Bug/错误\"), (\"Bug\", \"Bug/错误\"), (\"错误\", \"Bug/错误\"),\n    (\"失败\", \"Bug/错误\"), (\"缺陷\", \"Bug/错误\"), (\"漏洞\", \"Bug/错误\"),\n    (\"优化\", \"优化问题\"), (\"性能\", \"优化问题\"), (\"配置\", \"优化问题\"),\n]\n\nOTHER_KEYWORDS = [\n    \"问题\", \"无法\", \"不能\", \"差\", \"失望\", \"遗憾\", \"希望改进\", \"建议\", \"毛病\", \"不好\"\n]\n\n# ========== 飞书 API 函数 ==========\n\ndef get_feishu_access_token():\n    \"\"\"获取飞书访问令牌 (需要配置)\"\"\"\n    # 方式 1: 使用已保存的 token (推荐)\n    # 运行：openclaw configure --section feishu 来配置\n    try:\n        with open(\"~/.openclaw/feishu_token.json\", \"r\") as f:\n            token_data = json.load(f)\n            return token_data.get(\"access_token\")\n    except:\n        pass\n    \n    # 方式 2: 手动填入 (临时方案)\n    # 从飞书开放平台获取：https://open.feishu.cn/app\n    return None  # 需要配置\n\ndef create_feishu_record(fields):\n    \"\"\"在飞书表格中创建记录\"\"\"\n    access_token = get_feishu_access_token()\n    if not access_token:\n        print(\"⚠️  未配置飞书 API Token，跳过写入飞书\")\n        print(\"   配置方法：运行 'openclaw configure --section feishu'\")\n        return False\n    \n    url = f\"{FEISHU_API}/{FEISHU_APP_TOKEN}/tables/{FEISHU_TABLE_ID}/records\"\n    \n    headers = {\n        \"Authorization\": f\"Bearer {access_token}\",\n        \"Content-Type\": \"application/json\"\n    }\n    \n    data = {\"fields\": fields}\n    \n    try:\n        response = requests.post(url, headers=headers, json=data, timeout=10)\n        if response.status_code == 200:\n            return True\n        else:\n            print(f\"飞书 API 错误：{response.status_code} - {response.text}\")\n            return False\n    except Exception as e:\n        print(f\"飞书请求失败：{e}\")\n        return False\n\n# ========== Steam 评论爬取函数 ==========\n\ndef fetch_reviews(language=\"schinese\", filter_type=\"recent\", start_offset=0, num_reviews=100):\n    \"\"\"获取 Steam 评论\"\"\"\n    API_URL = f\"https://store.steampowered.com/appreviews/{APP_ID}\"\n    \n    params = {\n        \"json\": 1,\n        \"language\": language,\n        \"filter\": filter_type,\n        \"start_offset\": start_offset,\n        \"num_reviews\": num_reviews,\n        \"day_range\": \"9223372036854775807\"\n    }\n    \n    headers = {\n        \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36\"\n    }\n    \n    try:\n        response = requests.get(API_URL, params=params, headers=headers, timeout=10)\n        response.raise_for_status()\n        return response.json()\n    except requests.exceptions.RequestException as e:\n        print(f\"请求失败：{e}\")\n        return None\n\ndef analyze_review(text):\n    \"\"\"分析评论，提取问题类型和匹配关键词\"\"\"\n    matched_keywords = []\n    issue_types = set()\n    \n    text_lower = text.lower()\n    \n    for keyword, issue_type in GAME_ISSUE_KEYWORDS:\n        if keyword.lower() in text_lower:\n            matched_keywords.append(keyword)\n            issue_types.add(issue_type)\n    \n    for keyword in OTHER_KEYWORDS:\n        if keyword.lower() in text_lower:\n            matched_keywords.append(keyword)\n            if not issue_types:\n                issue_types.add(\"其他\")\n    \n    return list(matched_keywords), list(issue_types)\n\ndef parse_playtime(playtime_forever):\n    \"\"\"解析游戏时长\"\"\"\n    if not playtime_forever:\n        return \"未知\"\n    hours = playtime_forever // 60\n    if hours < 1:\n        return f\"{playtime_forever} 分钟\"\n    elif hours < 10:\n        return f\"{hours}.{playtime_forever % 60} 小时\"\n    else:\n        return f\"{hours} 小时\"\n\ndef save_reviews(reviews, filename=\"steam_reviews.json\"):\n    \"\"\"保存评论到 JSON 文件\"\"\"\n    with open(filename, \"w\", encoding=\"utf-8\") as f:\n        json.dump(reviews, f, ensure_ascii=False, indent=2)\n    print(f\"已保存 {len(reviews)} 条评论到 {filename}\")\n\ndef crawl_and_upload(max_pages=50, upload_to_feishu=True):\n    \"\"\"\n    爬取评论并上传到飞书\n    \n    参数:\n        max_pages: 最大爬取页数 (每页 100 条)\n        upload_to_feishu: 是否上传到飞书\n    \"\"\"\n    all_reviews = []\n    issue_reviews = []\n    uploaded_count = 0\n    offset = 0\n    \n    print(f\"🎮 开始爬取游戏 {APP_ID} 的简体中文评论...\")\n    print(f\"📄 最多爬取 {max_pages} 页 (每页 100 条)\")\n    print(f\"📊 飞书上传：{'开启' if upload_to_feishu else '关闭'}\")\n    print(\"=\" * 60)\n    \n    for page in range(max_pages):\n        print(f\"\\n📥 第 {page + 1} 页...\")\n        \n        data = fetch_reviews(start_offset=offset)\n        \n        if not data or data.get(\"success\") != 1:\n            print(\"❌ 无法获取评论，可能已达到最后一页\")\n            break\n        \n        reviews = data.get(\"reviews\", [])\n        if not reviews:\n            print(\"✅ 没有更多评论了\")\n            break\n        \n        print(f\"   获取到 {len(reviews)} 条评论\")\n        \n        for review in reviews:\n            all_reviews.append(review)\n            \n            # 分析评论\n            text = review.get(\"review\", \"\")\n            keywords, issue_types = analyze_review(text)\n            \n            # 如果匹配到关键词，保存并上传\n            if keywords:\n                issue_reviews.append({\n                    \"review\": review,\n                    \"keywords\": keywords,\n                    \"issue_types\": issue_types\n                })\n                \n                # 上传到飞书\n                if upload_to_feishu:\n                    fields = {\n                        \"评论内容\": text[:5000],  # 限制长度\n                        \"作者\": review.get(\"author\", {}).get(\"steamid\", \"匿名\"),\n                        \"推荐状态\": \"推荐\" if review.get(\"recommendationid\") else \"不推荐\",\n                        \"游戏时长\": parse_playtime(review.get(\"playtime_forever\")),\n                        \"评论日期\": review.get(\"timestamp_created\"),\n                        \"问题类型\": issue_types if issue_types else [\"其他\"],\n                        \"匹配关键词\": \", \".join(keywords[:10]),  # 最多 10 个关键词\n                        \"评论链接\": f\"https://steamcommunity.com/app/{APP_ID}/reviews/\",\n                        \"处理状态\": \"待处理\"\n                    }\n                    \n                    if create_feishu_record(fields):\n                        uploaded_count += 1\n                        if uploaded_count % 10 == 0:\n                            print(f\"   ✅ 已上传 {uploaded_count} 条到飞书\")\n                    time.sleep(0.2)  # 避免请求过快\n        \n        # 检查是否有下一页\n        total = data.get(\"query_summary\", {}).get(\"total_reviews\", 0)\n        if offset + 100 >= total:\n            print(\"✅ 已爬取全部评论\")\n            break\n        \n        offset += 100\n        time.sleep(0.5)\n    \n    # 保存 JSON 备份\n    save_reviews(all_reviews, f\"steam_reviews_{APP_ID}_all.json\")\n    \n    # 保存问题评论 (纯数据)\n    issue_data = [item[\"review\"] for item in issue_reviews]\n    save_reviews(issue_data, f\"steam_reviews_{APP_ID}_issues.json\")\n    \n    # 保存分析后的问题评论\n    with open(f\"steam_reviews_{APP_ID}_analyzed.json\", \"w\", encoding=\"utf-8\") as f:\n        json.dump(issue_reviews, f, ensure_ascii=False, indent=2)\n    \n    print(\"\\n\" + \"=\" * 60)\n    print(\"🎉 爬取完成!\")\n    print(f\"📊 总评论数：{len(all_reviews)}\")\n    print(f\"⚠️  问题相关评论：{len(issue_reviews)}\")\n    if upload_to_feishu:\n        print(f\"📤 已上传到飞书：{uploaded_count} 条\")\n        print(f\"🔗 飞书表格：https://xcnb9qtctplo.feishu.cn/base/{FEISHU_APP_TOKEN}\")\n    print(f\"📁 文件已保存:\")\n    print(f\"   - steam_reviews_{APP_ID}_all.json (全部评论)\")\n    print(f\"   - steam_reviews_{APP_ID}_issues.json (问题评论)\")\n    print(f\"   - steam_reviews_{APP_ID}_analyzed.json (分析后)\")\n\nif __name__ == \"__main__\":\n    print(\"🎮 Steam 评论爬取工具 - 飞书集成版\")\n    print(\"=\" * 60)\n    \n    # 检查是否安装了 requests\n    try:\n        import requests\n    except ImportError:\n        print(\"❌ 错误：需要先安装 requests 库\")\n        print(\"   运行：pip install requests\")\n        exit(1)\n    \n    # 询问是否上传到飞书\n    choice = input(\"\\n是否上传到飞书表格？(y/n, 默认 y): \").strip().lower()\n    upload = choice != \"n\"\n    \n    # 询问爬取页数\n    pages = input(\"爬取多少页？(每页 100 条，默认 50): \").strip()\n    max_pages = int(pages) if pages.isdigit() else 50\n    \n    crawl_and_upload(max_pages=max_pages, upload_to_feishu=upload)\n","path":"~/steam_review_crawler_feishu.py"}}],"api":"openai-completions","provider":"bailian","model":"qwen3.5-plus","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773709401486}}
