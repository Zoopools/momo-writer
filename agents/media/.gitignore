# ~/.media/.gitignore - 保护敏感凭证 + 资源管理

# ==================== 严禁提交的敏感文件 ====================

# 真实配置文件 (包含 Cookie/Token)
config.yaml
*.yaml
!config.yaml.template

# 备份文件
*.yaml.bak
*.yaml.backup
config.yaml.*

# 临时文件
*.tmp
*.swp
*.swo
*~

# 编辑器文件
.vscode/
.idea/
*.log

# ==================== 视频资源管理 (新增 2026-03-16) ====================

# 视频原素材 (禁止提交到 Git)
*.mp4
*.mov
*.avi
*.mkv
*.wmv
*.flv
*.webm
*.m4v

# 大型工程文件 (禁止提交到 Git)
*.prproj        # Premiere Pro
*.ae            # After Effects
*.aep           # After Effects Project
*.aeproj        # After Effects Project
*.fcpxml        # Final Cut Pro
*.fcpbundle     # Final Cut Pro Bundle
*.davinci       # DaVinci Resolve
*.drp           # DaVinci Resolve Project

# 音频文件 (大文件禁止)
*.wav
*.flac
*.aiff
*.m4a

# 图片文件 (仅允许小文件，大文件禁止)
# *.png        # 允许提交 (封面图等)
# *.jpg        # 允许提交 (封面图等)
# *.jpeg       # 允许提交 (封面图等)
*.psd           # Photoshop 源文件 (通常很大)
*.xcf           # GIMP 源文件

# 压缩包 (禁止提交)
*.zip
*.rar
*.7z
*.tar
*.gz

# 磁盘映像
*.dmg
*.iso
*.img

# ==================== 允许提交的文件 ====================

# 模板文件 (安全)
!config.yaml.template

# 文档
*.md
!README.md

# 轻量图片 (封面图、示意图，建议 <1MB)
*.png
*.jpg
*.jpeg
*.gif
*.webp

# 配置文件
*.json
*.toml
*.xml
