# Writer (墨墨) - 脱脂重构 .gitignore
# 创建时间: 2026-03-15
# 版本: 1.0

# 依赖目录
node_modules/
bun.lock
package-lock.json
yarn.lock

# 临时文件
*.tmp
*.log
.DS_Store
Thumbs.db

# 备份文件
*.backup
backup-*/
backup.*
*.bak*
.temp/

# 自动生成的状态文件
SESSION-STATE.backup.*

# 编辑器配置
.vscode/
.idea/
*.swp
*.swo
*~

# 测试文件
test/
tests/
__tests__/

# 输出目录
dist/
build/
out/

# 环境变量
.env
# OpenClaw Session Protection
*.lock
*.tmp
*.log
sessions/*.log
storage/db.lock
